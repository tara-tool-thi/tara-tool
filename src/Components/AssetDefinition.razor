@page "/Asset/{IdAsset:long}"
@inject AssetService AssetService
@inject TagService TagService
@inject NavigationManager NavigationManager

<h1>Asset Edit</h1>

<FluentTextField @bind-Value="@asset!.AssetName" Immediate=true ImmediateDelay="500" Label="Asset Name"
                 Placeholder="Enter asset name" />

<FluentTextField @bind-Value="@assetNumberInput" TextFieldType="TextFieldType.Number" Immediate=true
                 ImmediateDelay="500" Label="Asset Number (leave empty for autogenerated)" Placeholder="Enter asset number" />

@*ToDo: Think of a nice Tag Systeme*@
<FluentCombobox Autocomplete="ComboboxAutocomplete.Inline" @bind-Value="@selectedTagName" TOption="string">
    @foreach ()
</FluentCombobox>

@code {
    [Parameter]
    public long IdAsset { get; set; }

    private Asset? asset { get; set; }

    private string selectedTagName { get; set; } = string.Empty;

    private string assetNumberInput
    {
        get;
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                asset!.AssetNumber = -1;
                field = string.Empty;
                return;
            }
            long number = 0;
            if (long.TryParse(value, out number))
            {
                asset!.AssetNumber = number;
                field = number.ToString();
                return;
            }
            field = string.Empty;
        }
    } = string.Empty;

    private List<string> options = new();

    protected override async Task OnInitializedAsync()
    {
        asset = await AssetService.GetItemByIdAsync(IdAsset, include: q => q.Include(a => a.AssetGroup));

        if (asset is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }
    }




}