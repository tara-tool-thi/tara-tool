@using System.ComponentModel.DataAnnotations
@implements IDialogContentComponent<ApplicationUser>
@rendermode InteractiveServer

<FluentDialogHeader ShowDismiss="true">
    <h3>Reset Password</h3>
</FluentDialogHeader>


<FluentDialogBody>
    Are you sure you want to delete <strong>@Content.NameOfUser</strong>'s password? This cannot be undone.
    <FluentStack Orientation="Orientation.Horizontal" Class="margin-top-10">
    </FluentStack>
</FluentDialogBody>


<FluentDialogFooter>
        <FluentStack Orientation="Orientation.Horizontal" Width="100%" Style="gap: 0.5rem;">
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Outline" OnClick="@CancelDialog">Cancel</FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick=@CloseDialog BackgroundColor="var(--error)">Delete</FluentButton>
        </FluentStack>
 </FluentDialogFooter>


@code
{
    [Parameter]
    public ApplicationUser Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog? Dialog { get; set; }


    private async Task CloseDialog()
    {
        await Dialog!.CloseAsync();
    }

    private async Task CancelDialog()
    {
        await Dialog!.CancelAsync();
    }
}
