<FluentDialog Hidden="@(!showDeleteDialog)" Modal="true" TrapFocus="true" aria-label="Delete confirmation">
    <FluentDialogHeader>
        <h3>Delete Item</h3>
    </FluentDialogHeader>
    <FluentDialogBody>
        Are you sure you want to delete <strong>@ItemName</strong>? This cannot be undone.
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentStack Orientation="Orientation.Horizontal" Width="100%" Style="gap: 0.5rem;">
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Outline" OnClick="@Hide">Cancel
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" BackgroundColor="var(--error)" OnClick="OnDelete">Delete
            </FluentButton>
        </FluentStack>
    </FluentDialogFooter>
</FluentDialog>


@code {

    [Parameter, EditorRequired]
    public required string ItemName { get; set; }

    [Parameter, EditorRequired]
    public required EventCallback OnDelete { get; set; }

    private bool showDeleteDialog { get; set; } = false;

    public void Show()
    {
        showDeleteDialog = true;
    }

    public void Hide()
    {
        showDeleteDialog = false;
    }
}
