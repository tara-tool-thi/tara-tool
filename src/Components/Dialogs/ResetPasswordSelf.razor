@implements IDialogContentComponent<string>
@rendermode InteractiveServer

<FluentDialogHeader ShowDismiss="true">
    <h3>Reseting your own password</h3>
</FluentDialogHeader>

<FluentDialogBody>
    <FluentStack Orientation="Orientation.Vertical">
        <p>It is not possible to reset your own password on this page.
            <br />
        If you want to reset your password please do that
            <FluentAnchor Href="Account/Manage/ChangePassword" Appearance="Appearance.Hypertext">here</FluentAnchor>.
        </p>
    </FluentStack>
</FluentDialogBody>

<FluentDialogFooter>
    <FluentSpacer />
    <FluentButton Appearance="Appearance.Outline" OnClick="@CancelDialog">Cancel</FluentButton>
</FluentDialogFooter>


@code
{
    [Parameter]
    public string Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog? Dialog { get; set; }

    private async Task CloseDialog()
    {
        await Dialog!.CloseAsync();
    }
    private async Task CancelDialog()
    {
        await Dialog!.CancelAsync();
    }
}