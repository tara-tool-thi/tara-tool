@typeparam TEntity where TEntity : class
@implements IDisposable

<FluentIcon Id="SaveIcon" Value="@GetIcon" Color="@Color.Accent" @key=@saveStatus />
<FluentTooltip Anchor="SaveIcon">@tooltipString</FluentTooltip>

@code {

    [Parameter, EditorRequired]
    public required TEntity Entity { get; set; }

    [Parameter, EditorRequired]
    public required IDataService<TEntity> SaveService { get; set; } = default!;

    private System.Threading.Timer? saveTimer;
    private SaveStatus saveStatus = SaveStatus.Saved;


    public void ScheduleAutoSave()
    {
        saveStatus = SaveStatus.Unsaved;
        saveTimer?.Dispose();
        saveTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(SaveAsync);
        }, null, TimeSpan.FromSeconds(2), Timeout.InfiniteTimeSpan);
    }

    private async void SaveAsync()
    {
        saveStatus = SaveStatus.Saving;
        StateHasChanged();
        await SaveService.Save(Entity);
        saveStatus = SaveStatus.Saved;
        StateHasChanged();
    }

    private Icon GetIcon => saveStatus switch
    {
        SaveStatus.Saved => new Icons.Regular.Size20.CloudCheckmark(),
        SaveStatus.Saving => new Icons.Regular.Size20.CloudSync(),
        SaveStatus.Unsaved => new Icons.Regular.Size20.CloudEdit(),
        _ => new Icons.Regular.Size20.CloudCheckmark(),
    };

    private string tooltipString => saveStatus switch
    {
        SaveStatus.Saved => "All changes saved.",
        SaveStatus.Saving => "Saving changes…",
        SaveStatus.Unsaved => "Unsaved changes…",
        _ => "Unclear status…"
    };

    public void Dispose()
    {
        if (saveTimer is not null)
        {
            saveTimer.Dispose();
        }
    }

    private enum SaveStatus
    {
        Saved,
        Saving,
        Unsaved,
    }
}
