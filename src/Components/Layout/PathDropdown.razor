@using Humanizer
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using tara_tool.Data.Tables
@using tara_tool.Data.Services

@rendermode InteractiveServer

@inject NavigationManager Navigator
@inject ProjectService ProjectService
@inject ItemDefinitionService ItemService
@inject DamageScenarioService DamageScenarioService
@inject AssetService AssetService


<div @key=@rengedKey>
    @if (selectedProject is not null)
    {
        <FluentBreadcrumb @key=@rengedKey>
            <FluentBreadcrumbItem @key="@selectedProject">
                <FluentSelect TOption="Project" Height="250px" Class="path-dropdown-select"
                              Style="min-width: max(220px, 24ch);" Items="@AllProjects"
                              OptionText="@(p => p.Id == -1 ? "*" : p.ProjectName)" SelectedOptionChanged="@OnProjectChange"
                              Placeholder="Select" OptionSelected="@(p => p.Id == selectedProject?.Id)"
                              OptionValue="@(p => p.Id.ToString())" @key="@selectedProject" />
                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Slot="separator" />
            </FluentBreadcrumbItem>

            @if (selectedProject is not null)
            {
                <FluentBreadcrumbItem @key="@selectedItem">
                    <FluentSelect TOption="ItemDefinition" Height="250px" Class="path-dropdown-select"
                                  Style="min-width: max(220px, 24ch);" Items="@AllItems"
                                  OptionText="@(i => i.Id == -1 ? "*" :  i.ItemName)" OptionSelected="@(i => i.Id == selectedItem?.Id)"
                                  SelectedOptionChanged="@OnItemChanged" Placeholder="Select" OptionValue="@(p => p.Id.ToString())"
                                  @key="@selectedItem" />
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Slot="separator" />
                </FluentBreadcrumbItem>

                if (selectedItem is not null)
                {
                    <FluentBreadcrumbItem @key="@selectedItem">
                        <FluentSelect TOption="Asset" Height="250px" Class="path-dropdown-select"
                                      Style="min-width: max(220px, 24ch);" Items="@AllAssets"
                                      OptionText="@(a => a.Id == -1 ? "*" :  a.AssetName)" SelectedOptionChanged="OnAssetChange"
                                      OptionSelected="@(p => p.Id == selectedAsset?.Id)" Placeholder="Select"
                                      OptionValue="@(p => p.Id.ToString())" @key="@selectedAsset" />
                        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Slot="separator" />
                    </FluentBreadcrumbItem>
                }

                if (selectedAsset is not null)
                {
                    <FluentBreadcrumbItem @key="@selectedItem">
                        <FluentSelect TOption="DamageScenario" Height="250px" Class="path-dropdown-select"
                                      Style="min-width: max(220px, 24ch);" Items="@AllDamadgeScenarios"
                                      OptionText="@(p => p.Id == -1 ? "*" : p.DamageScenarioNumber.ToString())"
                                      OptionSelected="@(p => p.Id == selectedDamageScenario?.Id)"
                                      SelectedOptionChanged="@OnDamageScenarioChange" Placeholder="Select"
                                      OptionValue="@(p => p.Id.ToString())" @key="@selectedDamageScenario" />
                        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Slot="separator" />
                    </FluentBreadcrumbItem>
                }
            }

        </FluentBreadcrumb>
    }
</div>


@code {
    private List<Project> AllProjects = [];
    private List<ItemDefinition> AllItems = [];
    private List<Asset> AllAssets = [];
    private List<DamageScenario> AllDamadgeScenarios = [];
    private List<ThreatScenario> AllThreatScenarios = [];

    private long rengedKey
    {
        get
        {
            return (selectedProject?.GetHashCode() ?? 0) ^
                (selectedItem?.GetHashCode() ?? 0) ^
                (selectedAsset?.GetHashCode() ?? 0) ^
                (selectedThreatScenario?.GetHashCode() ?? 0) ^
                (selectedDamageScenario?.GetHashCode() ?? 0);
        }
    }



    protected override async Task OnInitializedAsync()
    {
        AllProjects = await ProjectService.GetProjectsAsync();
    }

    protected async override Task OnParametersSetAsync()
    {
        string url = Navigator.ToBaseRelativePath(Navigator.Uri);
        string[] urlSplitted = url.Split("/");

        //Prevent Resetting when in overview
        if (url.StartsWith("Overview")) return;

        //Reset State if we are not in a relevant path
        if (urlSplitted.Length != 2)
        {
            AllAssets.Clear();
            AllDamadgeScenarios.Clear();
            AllThreatScenarios.Clear();
            AllItems.Clear();
            selectedItem = null;
            selectedAsset = null;
            selectedDamageScenario = null;
            selectedThreatScenario = null;
            selectedProject = null;
            return;
        }
        ;

        string urlPrefix = urlSplitted[0];
        string id = urlSplitted[1];

        if (!long.TryParse(id, out long idLong)) return;


        // 👇 Guard: don't re-run if we're already showing this entity
        if (urlPrefix == "Project" && selectedProject?.Id == idLong) return;
        if (urlPrefix == "Item" && selectedItem?.Id == idLong) return;
        if (urlPrefix == "Asset" && selectedAsset?.Id == idLong) return;
        if (urlPrefix == "DamageScenario" && selectedDamageScenario?.Id == idLong) return;
        if (urlPrefix == "ThreatScenario" && selectedDamageScenario?.Id == idLong) return;

        //Listen to States -> Set Data -> reset otherwise
        if (urlPrefix == "Project")
        {
            if (long.TryParse(id, out long ProjectId))
            {
                Project? project = await ProjectService.GetItemByIdAsync(ProjectId, null);
                if (project is null) return;

                await HandleProjectChange(project, false);
            }
        }

        else if (urlPrefix == "Item")
        {
            if (long.TryParse(id, out long ItemId))
            {
                ItemDefinition? item = await ItemService.GetItemByIdAsync(ItemId, null);
                if (item is null) return;

                await HandleItemChange(item, false);
            }
        }

        else if (urlPrefix == "Asset")
        {
            if (long.TryParse(id, out long AssetId))
            {
                Asset? asset = await AssetService.GetItemByIdAsync(AssetId, null);
                if (asset is null) return;

                await HandleAssetChange(asset, false);
            }
        }

        else if (urlPrefix == "DamageScenario")
        {
            if (long.TryParse(id, out long DamageScenarioId))
            {
                DamageScenario? damageScenario = await DamageScenarioService.GetItemByIdAsync(DamageScenarioId, null);
                if (damageScenario is null) return;

                await HandleDamageScenarioChange(damageScenario, false);
            }
        }

        @* else if (urlPrefix == "ThreatScenario")
        {
            if (long.TryParse(id, out long ThreatScenarioId))
            {
                Threa? damageScenario = await Threa.GetItemByIdAsync(ThreatScenarioId, null);
                if(damageScenario is null) return;

                OnDamageScenarioChange(damageScenario);
            }
        } *@

        await InvokeAsync(StateHasChanged);
    }



    private string currentUrl = string.Empty;
    //Sorry to everyone, who needs to review this garbage -> I should have probably rewritten this from scratch. If you find
    // a better way/try to optimize this, please increase this number.Hours worked on this: 5 (I guess)


    private Project? selectedProject = null;
    private ItemDefinition? selectedItem = null;
    private Asset? selectedAsset = null;
    private DamageScenario? selectedDamageScenario = null;
    private ThreatScenario? selectedThreatScenario = null;

    private string SerializeCurrentState()
    {
        Dictionary<string, string?> query = new();

        if (selectedProject is not null)
            query["IdProject"] = selectedProject.Id.ToString();

        if (selectedItem is not null)
            query["IdItem"] = selectedItem.Id.ToString();

        if (selectedAsset is not null)
            query["IdAsset"] = selectedAsset.Id.ToString();

        if (selectedDamageScenario is not null)
            query["IdDamageScenario"] = selectedDamageScenario.Id.ToString();

        if (selectedThreatScenario is not null)
            query["IdThreatScenario"] = selectedThreatScenario.Id.ToString();

        return Navigator.GetUriWithQueryParameters("/Overview", query.ToDictionary(k => k.Key, v => (object?)v.Value));
    }


    private async Task HandleProjectChange(Project project, bool navigate = true)
    {
        AllAssets.Clear();
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        AllItems.Clear();
        selectedItem = null;
        selectedAsset = null;
        selectedDamageScenario = null;
        selectedThreatScenario = null;
        selectedProject = project;
        if (project.Id != -1)
        {
            AllItems.Add(new ItemDefinition
            {
                Id = -1,
                //Bypass limitations
                Project = default!,
            });
            AllItems.AddRange((await ItemService.GetItemsAsync(project.Id)));

            if (navigate)
                Navigator.NavigateTo($"/Project/{project.Id}");
        }
    }

    private async void OnProjectChange(Project project)
    {
        if (selectedProject?.Id == project.Id) return;
        await HandleProjectChange(project);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleItemChange(ItemDefinition itemDefinition, bool navigate = true)
    {
        AllAssets.Clear();
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        selectedAsset = null;
        selectedDamageScenario = null;
        selectedThreatScenario = null;
        selectedItem = itemDefinition;

        if (itemDefinition.Id != -1)
        {
            AllAssets.Add(new Asset
            {
                Id = -1,
            });
            AllAssets = (await AssetService.GetItems(selectedProject?.Id ?? 0, filter: q => q.Where(a => a.IdItemDefinition ==
itemDefinition.Id))).Item1;
            if (navigate) Navigator.NavigateTo($"/Item/{itemDefinition.Id}");
        }

        if (itemDefinition.Id == -1)
        {
            AllAssets.Add(new Asset
            {
                Id = -1,
            });
            Navigator.NavigateTo(SerializeCurrentState());
        }
    }

    private async void OnItemChanged(ItemDefinition itemDefinition)
    {
        if (selectedItem?.Id == itemDefinition.Id) return;
        await HandleItemChange(itemDefinition);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleAssetChange(Asset asset, bool navigate = true)
    {
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        selectedAsset = asset;
        selectedDamageScenario = null;
        selectedThreatScenario = null;

        if (asset.Id != -1)
        {

            AllDamadgeScenarios.Add(new DamageScenario
            {
                Id = -1,
            });
            AllDamadgeScenarios.AddRange((await DamageScenarioService.GetItems(selectedProject?.Id ?? 0, filter: q => q.Where(a =>
a.Asset!.Id == asset.Id))).Item1);
            if (navigate) Navigator.NavigateTo($"/Asset/{asset.Id}");
        }
        if (asset.Id == -1)
        {
            AllDamadgeScenarios.Add(new DamageScenario
            {
                Id = -1,
            });
            Navigator.NavigateTo(SerializeCurrentState());
        }
    }

    private async void OnAssetChange(Asset asset)
    {
        if (selectedAsset?.Id == asset.Id) return;
        await HandleAssetChange(asset);
        await InvokeAsync(StateHasChanged);
    }

    //ToDo: Add when ThreaScenarioService is finished

