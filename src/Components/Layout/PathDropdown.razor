@using tara_tool.Data.Tables
@using tara_tool.Data.Services

@rendermode InteractiveServer

@implements IDisposable
@inject NavigationManager Navigator
@inject ProjectService ProjectService
@inject ItemDefinitionService ItemService
@inject DamageScenarioService DamageScenarioService
@inject AssetService AssetService
@inject ThreatScenarioService ThreatScenarioService

<div class="path-dropdown-scroll-container">
    <FluentStack Orientation="Orientation.Horizontal">
        @if (selectedProject is not null)
        {
            <div class="path-dropdown-step" @key="@($"selected-project-{selectedProject.Id}")">
                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon"/>
                <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select"
                              OnClick="@(() => HandleProjectChange(selectedProject, true))">
                    @(selectedProject.Id == -1 ? "All Projects" : selectedProject.ProjectName)
                </FluentButton>
                <FluentButton Id="project-menu-anchor" Appearance="Appearance.Lightweight" Class="path-dropdown-select" OnClick="@(() => _projectMenuOpen = !_projectMenuOpen)">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon"/>
                </FluentButton>
                <FluentMenu Anchor="project-menu-anchor" @bind-Open="_projectMenuOpen" UseMenuService="true">
                    @foreach (Project p in AllProjects)
                    {
                        <FluentMenuItem OnClick="@(() => OnProjectChange(p))"
                                        Selected="@(p.Id == selectedProject?.Id)">
                            @(p.Id == -1 ? "All Projects" : p.ProjectName)
                        </FluentMenuItem>
                    }
                </FluentMenu>
            </div>

            <div class="path-dropdown-step" @key="@($"selected-item-{selectedItem?.Id ?? 0}")">
                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                @if (selectedItem is not null)
                {
                    <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select"
                                  OnClick="@(() => HandleItemChange(selectedItem, true))">
                        @(selectedItem.Id == -1 ? "All Items" : selectedItem.ItemName)
                    </FluentButton>
                }
                else
                {
                    <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select path-dropdown-select-placeholder" OnClick="@(() => _itemMenuOpen = !_itemMenuOpen)">
                        Select Item
                    </FluentButton>
                }
                <FluentButton Id="item-menu-anchor" Appearance="Appearance.Lightweight" Class="path-dropdown-select" OnClick="@(() => _itemMenuOpen = !_itemMenuOpen)">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                </FluentButton>
                <FluentMenu Anchor="item-menu-anchor" @bind-Open="_itemMenuOpen" UseMenuService="true">
                    @foreach (ItemDefinition i in AllItems)
                    {
                        <FluentMenuItem OnClick="@(() => OnItemChanged(i))"
                                        Selected="@(i.Id == selectedItem?.Id)">
                            @(i.Id == -1 ? "All Items" : i.ItemName)
                        </FluentMenuItem>
                    }
                </FluentMenu>
            </div>

            @if (selectedItem is not null)
            {
                <div class="path-dropdown-step" @key="@($"selected-asset-{selectedAsset?.Id ?? 0}")">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                    @if (selectedAsset is not null)
                    {
                        <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select"
                                      OnClick="@(() => HandleAssetChange(selectedAsset, true))">
                            @(selectedAsset.Id == -1 ? "All Assets" : selectedAsset.AssetName)
                        </FluentButton>
                    }
                    else
                    {
                        <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select path-dropdown-select-placeholder" OnClick="@(() => _assetMenuOpen = !_assetMenuOpen)">
                            Select Asset
                        </FluentButton>
                    }
                    <FluentButton Id="asset-menu-anchor" Appearance="Appearance.Lightweight" Class="path-dropdown-select" OnClick="@(() => _assetMenuOpen = !_assetMenuOpen)">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                    </FluentButton>
                    <FluentMenu Anchor="asset-menu-anchor" @bind-Open="_assetMenuOpen" UseMenuService="true">
                        @foreach (Asset a in AllAssets)
                        {
                            <FluentMenuItem OnClick="@(() => OnAssetChange(a))"
                                            Selected="@(a.Id == selectedAsset?.Id)">
                                @(a.Id == -1 ? "All Assets" : a.AssetName)
                            </FluentMenuItem>
                        }
                    </FluentMenu>
                </div>

                @if (selectedAsset is not null)
                {
                    <div class="path-dropdown-step" @key="@($"selected-damage-{selectedDamageScenario?.Id ?? 0}")">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                        @if (selectedDamageScenario is not null)
                        {
                            <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select"
                                          OnClick="@(() => HandleDamageScenarioChange(selectedDamageScenario, true))">
                                @(selectedDamageScenario.Id == -1 ? "All Damage Scenarios" : ($"Damage Scenario {selectedDamageScenario.DamageScenarioNumber.ToString()}"))
                            </FluentButton>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select path-dropdown-select-placeholder" OnClick="@(() => _damageMenuOpen = !_damageMenuOpen)">
                                Select Damage Scenario
                            </FluentButton>
                        }
                        <FluentButton Id="damagescenario-menu-anchor" Appearance="Appearance.Lightweight" Class="path-dropdown-select" OnClick="@(() => _damageMenuOpen = !_damageMenuOpen)">
                            <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                        </FluentButton>
                        <FluentMenu Anchor="damagescenario-menu-anchor" @bind-Open="_damageMenuOpen" UseMenuService="true">
                            @foreach (DamageScenario d in AllDamadgeScenarios)
                            {
                                <FluentMenuItem OnClick="@(() => OnDamageScenarioChange(d))"
                                                Selected="@(d.Id == selectedDamageScenario?.Id)">
                                    @(d.Id == -1 ? "All Damage Scenarios" : ($"Damage Scenario {d.DamageScenarioNumber.ToString()}"))
                                </FluentMenuItem>
                            }
                        </FluentMenu>
                    </div>

                    @if (selectedDamageScenario is not null)
                    {
                        <div class="path-dropdown-step" @key="@($"selected-threat-{selectedThreatScenario?.Id ?? 0}")">
                            <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                            @if (selectedThreatScenario is not null)
                            {
                                <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select"
                                              OnClick="@(() => HandleThreatScenarioChange(selectedThreatScenario, true))">
                                    @(selectedThreatScenario.Id == -1 ? "All Threat Scenarios" : selectedThreatScenario.Name)
                                </FluentButton>
                            }
                            else
                            {
                                <FluentButton Appearance="Appearance.Lightweight" Class="path-dropdown-select path-dropdown-select-placeholder" OnClick="@(() => _threatMenuOpen = !_threatMenuOpen)">
                                    Select Threat Scenario
                                </FluentButton>
                            }
                            <FluentButton Id="threatscenario-menu-anchor" Appearance="Appearance.Lightweight" Class="path-dropdown-select" OnClick="@(() => _threatMenuOpen = !_threatMenuOpen)">
                                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Fill" Class="path-dropdown-scroll-container-icon" />
                            </FluentButton>
                            <FluentMenu Anchor="threatscenario-menu-anchor" @bind-Open="_threatMenuOpen" UseMenuService="true">
                                @foreach (ThreatScenario t in AllThreatScenarios)
                                {
                                    <FluentMenuItem OnClick="@(() => OnThreatScenarioChange(t))"
                                                    Selected="@(t.Id == selectedThreatScenario?.Id)">
                                        @(t.Id == -1 ? "All Threat Scenarios" : t.Name)
                                    </FluentMenuItem>
                                }
                            </FluentMenu>
                        </div>
                    }
                }
            }
        }
    </FluentStack>
</div>

@code {
    private List<Project> AllProjects = [];
    private List<ItemDefinition> AllItems = [];
    private List<Asset> AllAssets = [];
    private List<DamageScenario> AllDamadgeScenarios = [];
    private List<ThreatScenario> AllThreatScenarios = [];

    private bool _projectMenuOpen;
    private bool _itemMenuOpen;
    private bool _assetMenuOpen;
    private bool _damageMenuOpen;
    private bool _threatMenuOpen;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        // Marshal back to Blazor's sync context, then trigger async work + re-render
        _ = InvokeAsync(async () =>
        {
            await HandleCurrentUrl();
            StateHasChanged();
        });
    }


    protected override async Task OnInitializedAsync()
    {
        Navigator.LocationChanged += OnLocationChanged;
        await HandleCurrentUrl();
    }

    protected async Task HandleCurrentUrl()
    {
        string url = Navigator.ToBaseRelativePath(Navigator.Uri);
        string[] urlSplitted = url.Split("/");

        if (url.StartsWith("Overview"))
        {
            await HandleOverviewUrl(url);
            return;
        }

        //Reset State if we are not in a relevant path
        if (urlSplitted.Length != 2)
        {
            AllAssets.Clear();
            AllDamadgeScenarios.Clear();
            AllThreatScenarios.Clear();
            AllItems.Clear();
            selectedItem = null;
            selectedAsset = null;
            selectedDamageScenario = null;
            selectedThreatScenario = null;
            selectedProject = null;
            _projectMenuOpen = false;
            _itemMenuOpen = false;
            _assetMenuOpen = false;
            _damageMenuOpen = false;
            _threatMenuOpen = false;
            StateHasChanged();
            return;
        }
        ;

        string urlPrefix = urlSplitted[0];
        string id = urlSplitted[1];

        if (!long.TryParse(id, out long idLong)) return;


        // 👇 Guard: don't re-run if we're already showing this entity
        if (urlPrefix == "Project" && selectedProject?.Id == idLong) return;
        if (urlPrefix == "Item" && selectedItem?.Id == idLong) return;
        if (urlPrefix == "Asset" && selectedAsset?.Id == idLong) return;
        if (urlPrefix == "DamageScenario" && selectedDamageScenario?.Id == idLong) return;
        if (urlPrefix == "ThreatScenario" && selectedThreatScenario?.Id == idLong) return;

        //Listen to States -> Set Data -> reset otherwise
        if (urlPrefix == "Project")
        {
            if (long.TryParse(id, out long ProjectId))
            {
                Project? project = await ProjectService.GetItemByIdAsync(ProjectId, null);
                if (project is null) return;

                await HandleProjectChange(project, false);
            }
        }

        else if (urlPrefix == "Item")
        {
            if (long.TryParse(id, out long ItemId))
            {
                ItemDefinition? item = await ItemService.GetItemByIdAsync(ItemId, q => q.Include(p => p.Project));
                if (item is null) return;

                await HandleProjectChange(item.Project, false);
                await HandleItemChange(item, false);
            }
        }

        else if (urlPrefix == "Asset")
        {
            if (long.TryParse(id, out long AssetId))
            {
                Asset? asset = await AssetService.GetItemByIdAsync(AssetId, q => q.Include(a => a.ItemDefinition).ThenInclude(a =>
a!.Project));
                if (asset is null) return;

                await HandleProjectChange(asset.ItemDefinition!.Project, false);
                await HandleItemChange(asset.ItemDefinition!, false);
                await HandleAssetChange(asset, false);
            }
        }

        else if (urlPrefix == "DamageScenario")
        {
            if (long.TryParse(id, out long DamageScenarioId))
            {
                DamageScenario? damageScenario = await DamageScenarioService.GetItemByIdAsync(DamageScenarioId, q => q.Include(d =>
d.Asset).ThenInclude(a => a!.ItemDefinition).ThenInclude(i => i!.Project));
                if (damageScenario is null) return;


                await HandleProjectChange(damageScenario.Asset!.ItemDefinition!.Project, false);
                await HandleItemChange(damageScenario.Asset!.ItemDefinition, false);
                await HandleAssetChange(damageScenario.Asset!, false);
                await HandleDamageScenarioChange(damageScenario, false);
            }
        }

        else if (urlPrefix == "ThreatScenario")
        {
            if (long.TryParse(id, out long ThreatScenarioId))
            {
                ThreatScenario? threatScenario = await ThreatScenarioService.GetItemByIdAsync(ThreatScenarioId,
                    q => q.Include(t => t.DamageScenarios).ThenInclude(d => d!.Asset).ThenInclude(a => a!.ItemDefinition).ThenInclude(i => i!.Project));
                if (threatScenario is null) return;

                await HandleProjectChange(threatScenario.DamageScenarios!.Asset!.ItemDefinition!.Project, false);
                await HandleItemChange(threatScenario.DamageScenarios!.Asset!.ItemDefinition!, false);
                await HandleAssetChange(threatScenario.DamageScenarios!.Asset!, false);
                await HandleDamageScenarioChange(threatScenario.DamageScenarios!, false);
                await HandleThreatScenarioChange(threatScenario, false);
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private string currentUrl = string.Empty;

    private Project? selectedProject = null;
    private ItemDefinition? selectedItem = null;
    private Asset? selectedAsset = null;
    private DamageScenario? selectedDamageScenario = null;
    private ThreatScenario? selectedThreatScenario = null;

    private string SerializeCurrentState()
    {
        Dictionary<string, string?> query = new();

        if (selectedProject is not null)
            query["IdProject"] = selectedProject.Id.ToString();

        if (selectedItem is not null)
            query["IdItem"] = selectedItem.Id.ToString();

        if (selectedAsset is not null)
            query["IdAsset"] = selectedAsset.Id.ToString();

        if (selectedDamageScenario is not null)
            query["IdDamageScenario"] = selectedDamageScenario.Id.ToString();

        if (selectedThreatScenario is not null)
            query["IdThreatScenario"] = selectedThreatScenario.Id.ToString();

        return Navigator.GetUriWithQueryParameters("/Overview", query.ToDictionary(k => k.Key, v => (object?)v.Value));
    }


    private async Task HandleProjectChange(Project? project, bool navigate = true)
    {
        if (project == null) return;
        AllAssets.Clear();
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        AllItems.Clear();
        AllProjects.Clear();
        AllProjects = await ProjectService.GetProjectsAsync();
        selectedItem = null;
        selectedAsset = null;
        selectedDamageScenario = null;
        selectedThreatScenario = null;
        selectedProject = project;
        if (project.Id != -1)
        {
            AllItems.Add(new ItemDefinition
            {
                Id = -1,
                //Bypass limitations
                Project = default!,
            });
            AllItems.AddRange((await ItemService.GetItemsAsync(project.Id)));

            if (navigate)
                Navigator.NavigateTo($"/Project/{project.Id}");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async void OnProjectChange(Project project)
    {
        _projectMenuOpen = false;
        if (selectedProject?.Id == project.Id) return;
        await HandleProjectChange(project);
    }

    private async Task HandleItemChange(ItemDefinition? itemDefinition, bool navigate = true)
    {
        if (itemDefinition == null) return;
        _itemMenuOpen = false;
        AllAssets.Clear();
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        selectedAsset = null;
        selectedDamageScenario = null;
        selectedThreatScenario = null;
        selectedItem = itemDefinition;

        if (itemDefinition.Id != -1)
        {
            AllAssets.Add(new Asset
            {
                Id = -1,
            });
            AllAssets.AddRange((await AssetService.GetItems(selectedProject?.Id ?? 0, filter: q => q.Where(a => a.IdItemDefinition
==
itemDefinition.Id))).Item1);
            if (navigate) Navigator.NavigateTo($"/Item/{itemDefinition.Id}");
        }

        if (itemDefinition.Id == -1)
        {
            AllAssets.Add(new Asset
            {
                Id = -1,
            });
            Navigator.NavigateTo(SerializeCurrentState());
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnItemChanged(ItemDefinition itemDefinition)
    {
        _itemMenuOpen = false;
        if (selectedItem?.Id == itemDefinition.Id) return;
        await HandleItemChange(itemDefinition);
    }

    private async Task HandleAssetChange(Asset? asset, bool navigate = true)
    {
        if (asset == null) return;
        _assetMenuOpen = false;
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        selectedAsset = asset;
        selectedDamageScenario = null;
        selectedThreatScenario = null;

        if (asset.Id != -1)
        {

            AllDamadgeScenarios.Add(new DamageScenario
            {
                Id = -1,
            });
            AllDamadgeScenarios.AddRange((await DamageScenarioService.GetItems(selectedProject?.Id ?? 0, filter: q => q.Where(a =>
a.Asset!.Id == asset.Id))).Item1);
            if (navigate) Navigator.NavigateTo($"/Asset/{asset.Id}");
        }
        if (asset.Id == -1)
        {
            AllDamadgeScenarios.Add(new DamageScenario
            {
                Id = -1,
            });
            Navigator.NavigateTo(SerializeCurrentState());
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAssetChange(Asset asset)
    {
        _assetMenuOpen = false;
        if (selectedAsset?.Id == asset.Id) return;
        await HandleAssetChange(asset);
    }

    //ToDo: Add when ThreaScenarioService is finished

    private async Task HandleDamageScenarioChange(DamageScenario? damageScenario, bool navigate = true)
    {
        if (damageScenario == null) return;
        _damageMenuOpen = false;
        AllThreatScenarios.Clear();
        selectedDamageScenario = damageScenario;
        selectedThreatScenario = null;

        if (damageScenario.Id != -1)
        {

            AllThreatScenarios.Add(new ThreatScenario
            {
                Id = -1,
            });
            AllThreatScenarios.AddRange((await ThreatScenarioService.GetItems(
                selectedProject?.Id ?? 0,
                filter: q => q.Where(t => t.DamageScenarios!.Id == damageScenario.Id))).Item1);
            if (navigate) Navigator.NavigateTo($"/DamageScenario/{damageScenario.Id}");
        }

        if (damageScenario.Id == -1)
        {
            AllThreatScenarios.Add(new ThreatScenario
            {
                Id = -1,
            });
            Navigator.NavigateTo(SerializeCurrentState());
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDamageScenarioChange(DamageScenario damageScenario)
    {
        _damageMenuOpen = false;
        if (selectedDamageScenario?.Id == damageScenario.Id) return;
        await HandleDamageScenarioChange(damageScenario);
    }

    private async Task HandleThreatScenarioChange(ThreatScenario? threatScenario, bool navigate = true)
    {
        if (threatScenario == null) return;
        _threatMenuOpen = false;
        selectedThreatScenario = threatScenario;

        if (threatScenario.Id != -1)
        {
            if (navigate) Navigator.NavigateTo($"/ThreatScenario/{threatScenario.Id}");
        }
        if (threatScenario.Id == -1)
        {
            Navigator.NavigateTo(SerializeCurrentState());
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnThreatScenarioChange(ThreatScenario threatScenario)
    {
        _threatMenuOpen = false;
        if (selectedThreatScenario?.Id == threatScenario.Id) return;
        await HandleThreatScenarioChange(threatScenario);
    }

    private async Task HandleOverviewUrl(string url)
    {
        int queryStart = url.IndexOf('?');
        if (queryStart < 0) return;

        Microsoft.Extensions.Primitives.StringValues pv, iv, av, dv, tv;
        System.Collections.Generic.Dictionary<string, Microsoft.Extensions.Primitives.StringValues> queryParams =
            Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(url.Substring(queryStart));

        if (!queryParams.TryGetValue("IdProject", out pv) || !long.TryParse(pv, out long idProject)) return;
        long? idItem = queryParams.TryGetValue("IdItem", out iv) && long.TryParse(iv, out long i) ? i : (long?)null;
        long? idAsset = queryParams.TryGetValue("IdAsset", out av) && long.TryParse(av, out long a) ? a : (long?)null;
        long? idDs = queryParams.TryGetValue("IdDamageScenario", out dv) && long.TryParse(dv, out long d) ? d : (long?)null;
        long? idTs = queryParams.TryGetValue("IdThreatScenario", out tv) && long.TryParse(tv, out long t) ? t : (long?)null;

        // Guard: already showing this exact state — avoid unnecessary reloads on in-page navigation
        if (selectedProject?.Id == idProject &&
            selectedItem?.Id == idItem &&
            selectedAsset?.Id == idAsset &&
            selectedDamageScenario?.Id == idDs &&
            selectedThreatScenario?.Id == idTs)
            return;

        AllProjects.Clear();
        AllItems.Clear();
        AllAssets.Clear();
        AllDamadgeScenarios.Clear();
        AllThreatScenarios.Clear();
        selectedProject = null;
        selectedItem = null;
        selectedAsset = null;
        selectedDamageScenario = null;
        selectedThreatScenario = null;

        AllProjects = await ProjectService.GetProjectsAsync();
        Project? project = await ProjectService.GetItemByIdAsync(idProject, null);
        if (project is null) return;
        selectedProject = project;

        if (idItem is null) return;

        AllItems.Add(new ItemDefinition { Id = -1, Project = default! });
        AllItems.AddRange(await ItemService.GetItemsAsync(project.Id));

        if (idItem == -1)
        {
            selectedItem = AllItems.First(x => x.Id == -1);
            AllAssets.Add(new Asset { Id = -1 });
            return;
        }

        ItemDefinition? item = AllItems.FirstOrDefault(x => x.Id == idItem);
        if (item is null) return;
        selectedItem = item;

        if (idAsset is null) return;

        AllAssets.Add(new Asset { Id = -1 });
        AllAssets.AddRange((await AssetService.GetItems(project.Id, filter: q => q.Where(x => x.IdItemDefinition == idItem))).Item1);

        if (idAsset == -1)
        {
            selectedAsset = AllAssets.First(x => x.Id == -1);
            AllDamadgeScenarios.Add(new DamageScenario { Id = -1 });
            return;
        }

        Asset? asset = AllAssets.FirstOrDefault(x => x.Id == idAsset);
        if (asset is null) return;
        selectedAsset = asset;

        if (idDs is null) return;

        AllDamadgeScenarios.Add(new DamageScenario { Id = -1 });
        AllDamadgeScenarios.AddRange((await DamageScenarioService.GetItems(project.Id, filter: q => q.Where(x => x.Asset!.Id == idAsset))).Item1);

        if (idDs == -1)
        {
            selectedDamageScenario = AllDamadgeScenarios.First(x => x.Id == -1);
            AllThreatScenarios.Add(new ThreatScenario { Id = -1 });
            return;
        }

        DamageScenario? damageScenario = AllDamadgeScenarios.FirstOrDefault(x => x.Id == idDs);
        if (damageScenario is null) return;
        selectedDamageScenario = damageScenario;

        if (idTs is null) return;

        AllThreatScenarios.Add(new ThreatScenario { Id = -1 });
        AllThreatScenarios.AddRange((await ThreatScenarioService.GetItems(project.Id, filter: q => q.Where(x => x.DamageScenarios!.Id == idDs))).Item1);

        if (idTs == -1)
        {
            selectedThreatScenario = AllThreatScenarios.First(x => x.Id == -1);
            return;
        }

        ThreatScenario? threatScenario = AllThreatScenarios.FirstOrDefault(x => x.Id == idTs);
        if (threatScenario is null) return;
        selectedThreatScenario = threatScenario;
    }

    public void Dispose()
    {
        Navigator.LocationChanged -= OnLocationChanged;
    }
}
