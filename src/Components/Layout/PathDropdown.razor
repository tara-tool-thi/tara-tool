    {

    }

    private async Task OnDamageScenarioChange(DamageScenario damageScenario)
    {

    }

    private async Task HandleThreatScenarioChange(ThreatScenario threatScenario, bool navigate = true)
    {

    }

    private async Task OnThreatScenarioChange(ThreatScenario threatScenario)
    {

    }
}
