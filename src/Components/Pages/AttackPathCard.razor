@using Microsoft.FluentUI.AspNetCore.Components

<div style="border: 1px solid #8a8886; border-radius: 4px; background-color: #ffffff; overflow: visible; width: 100%">
    @* Header Bar *@
    <div style="background-color: #f3f2f1; padding: 8px 15px; display: flex; align-items: center; border-bottom: 1px solid #8a8886;">
        <div style="font-weight: bold; color: #323130; border: 1px solid #8a8886; padding: 2px 8px;">@("AP" + Data.Label)</div>
        <FluentSpacer Width="12"/>
        <div style="font-weight: bold; color: #323130;">In'N'Out</div>
    </div>

    <FluentGrid Spacing="2" Style="padding: 10px;">
        @* LEFT COLUMN: The Steps Table *@
        <FluentGridItem xs="6">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                <thead style="background-color: #f3f2f1;">
                    <tr>
                        <th style="border: 1px solid #8a8886; padding: 4px; width: 40px; height: 40px; text-align: center;">#</th>
                        <th style="border: 1px solid #8a8886; padding: 4px;">Steps</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (string step in Data.Steps)
                    {
                        <tr>
                            <td style="border: 1px solid #8a8886; text-align: center; padding: 4px; height: 40px; background-color: #f3f2f1;">@index</td>
                            <td style="border: 1px solid #8a8886; padding: 4px;"><FluentTextField Value="@step"/></td>
                        </tr>
                        ++index;
                    }
                    <tr>
                        <td style="border: 1px solid #8a8886; text-align: center; padding: 4px; height: 40px; background-color: #f3f2f1;">@index</td>
                        <td style="border: 1px solid #8a8886; padding: 4px;"><FluentTextField Placeholder="Add new step..." /></td>
                    </tr>
                </tbody>
            </table>

            @* Risk Decision Section *@
            <div style="margin-top: 15px; border: 1px solid #8a8886; padding: 10px; background-color: #faf9f8;">
                <FluentStack Orientation="Orientation.Horizontal">
                    <span style="font-size: 0.8rem;">Risk treatment decision</span>
                    <FluentSpacer/>
                    <FluentCheckbox @bind-Value="IsDone" /> Done
                </FluentStack>
                <FluentTextArea Style="width: 100%; margin-top: 5px;" Placeholder="Hide Info" @bind-Value="@Data.RiskTreatment"/>
            </div>
        </FluentGridItem>

        

        @* RIGHT COLUMN: Dropdown Inputs *@
        <FluentGridItem xs="6" Style="border-left: 1px solid #8a8886; ">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                <div>
                    <span style="font-size: 0.8rem; color: #605e5c;">Elapsed Time</span><br/>
                    <FluentSelect Items="@(new[] { "< 1 day", "< 1 week", "< 1 month", "< 6 months", "> 6 months" })" Style="width: 100%;" />
                </div>

                <div>
                    <span style="font-size: 0.8rem; color: #605e5c;">Specialist Expertise</span><br/>
                    <FluentSelect Items="@(new[] { "Layman", "Proficient", "Expert", "Multiple experts" })" Style="width: 100%;" />
                </div>

                <div>
                    <span style="font-size: 0.8rem; color: #605e5c;">Knowledge of Item</span><br/>
                    <FluentSelect Items="@(new[] { "Public", "Restricted", "Confidential", "Strictly confidential" })" Style="width: 100%;" />
                </div>

                <div>
                    <span style="font-size: 0.8rem; color: #605e5c;">Window of Opportunity</span><br/>
                    <FluentSelect Items="@(new[] { "Unlimited", "Easy", "Moderate", "Difficult" })" Style="width: 100%;" />
                </div>

                <div>
                    <span style="font-size: 0.8rem; color: #605e5c;">Equipment</span><br/>
                    <FluentSelect Items="@(new[] { "Standard", "Specialized", "Bespoke", "Multiple Bespoke" })" Style="width: 100%;" />
                </div>

                <div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #edebe9; width: 100%;">
                    <FluentStack Orientation="Orientation.Vertical">
                        
                            <div style="font-size: 0.75rem; color: #d13438; width: 100%;">
                                <FluentStack>
                                    <span>Attack Feasibility:</span>
                                    <FluentSpacer />
                                    <span>High</span>
                                </FluentStack>
                            </div> 
                            <div style="font-size: 1rem; font-weight: bold; color: #d13438; width: 100%;">
                                <FluentStack>
                                    <span>Risk Value:</span>
                                    <FluentSpacer />
                                    <span>S5</span>
                                </FluentStack>
                            </div>
                        
                    </FluentStack>
                </div>
            </FluentStack>
        </FluentGridItem>
    </FluentGrid>
</div>

@code {
    [Parameter] public AttackPathModel Data { get; set; } = default!;

    private bool IsDone { get; set; } = false;
}
