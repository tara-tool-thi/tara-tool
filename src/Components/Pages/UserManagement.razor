@page "/UserManagement"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using System.Security.Cryptography.Pkcs
@rendermode InteractiveServer

@inject IDialogService _dialogService

@attribute [Authorize]

<PageTitle>User Management</PageTitle>

<h1>User Management</h1>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Stretch"
        HorizontalAlignment="HorizontalAlignment.SpaceBetween">
    <FluentSearch Placeholder="Type to search for user..." Style="Width: 25%" @bind-Value=@UserSearch />
    <FluentButton OnClick="OpenDialog">
      + New User
    </FluentButton>
</FluentStack>


@code {
    private string? UserSearch;

    private InputModel Input { get; set; } = new InputModel(); 

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
    private async Task OpenDialog()
    {
        IDialogReference dialogInstance = await _dialogService.ShowDialogAsync(
            @<div>
                <EditForm Model="Input" method="post" OnSubmit="submit" FormName="addUser">
                    <DataAnnotationsValidator />
                    <FluentTextField Name="Input.Email" TextFieldType="TextFieldType.Email" @bind-Value=Input.Email Placeholder="example@thi.de" Label="Enter email address:" Required="true" />
                    <FluentValidationMessage For="() => Input.Email" class="text-danger" />
                </EditForm>
            </div>
    , new DialogParameters
    {
        Title = "Invite new user",
    });

        DialogResult result = await dialogInstance.Result;
        if (!result.Cancelled)
        {
        }
    }

    public async Task createLink()
    {
        await _dialogService.ShowSuccessAsync($"Email sent to: {Input.Email}", "Success");
    }

    public async Task invalidSubmit()
    {

    }

    public async Task submit()
    {
        await _dialogService.ShowSuccessAsync($"Email sent to: {Input.Email}", "Success");
    }

}
