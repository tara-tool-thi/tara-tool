@using System.ComponentModel.DataAnnotations
@using Microsoft.FluentUI.AspNetCore.Components.DesignTokens


@if (isLastLayer)
{
    @switch (CurrentLayer)
    {
        case Layer.Project:
            break;
        case Layer.Asset:
            break;
        case Layer.Item:
            break;
        case Layer.DamageScenario:
            break;
        case Layer.ThreatScenario:
            break;
    }
}
else
{

}


@code {

    [Parameter, Required, EditorRequired]
    public required bool isTopLayer { get; set; }

    [Parameter, Required, EditorRequired]
    public required Layer CurrentLayer { get; set; }

    [Parameter, Required, EditorRequired]
    public required Layer TargetLayer { get; set; }

    [Parameter, Required, EditorRequired]
    public required string FreeTextSearchString { get; set; }

    private bool isLastLayer { get; set; } = false;

    private List<KeyValuePair<long, string>> optionsForThisLayer { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        isLastLayer = CurrentLayer == TargetLayer;
    }


    public enum Layer
    {
        ThreatScenario = 0,
        DamageScenario = 1,
        Asset = 2,
        Item = 3,
        Project = 4,
    }
}