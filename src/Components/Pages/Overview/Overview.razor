@page "/Overview"
@using Mono.TextTemplating

@rendermode InteractiveServer
@inject NavigationManager Navigator


@if (topLayer is not null && bottomLayer is not null)
{
    <OverviewElement IdProject="@IdProject" IdAsset="@IdAsset" IdDamageScenario=@IdDamageScenario IdItem=@IdItem
                     IdThreatScenario="@IdThreatScenario" LastLayer=@((LayerType)bottomLayer)
                     CurrentLayer="@((LayerType)topLayer)" SearchText="@searchText" @key=@renderKey />
}


@code {

    private long renderKey = 0;

    [SupplyParameterFromQuery]
    public long? IdProject { get; set; } = null;

    [SupplyParameterFromQuery]
    public long? IdItem { get; set; } = null;

    [SupplyParameterFromQuery]
    public long? IdAsset { get; set; } = null;

    [SupplyParameterFromQuery]
    public long? IdDamageScenario { get; set; } = null;

    [SupplyParameterFromQuery]
    public long? IdThreatScenario { get; set; } = null;

    private LayerType? topLayer = null;
    private LayerType? bottomLayer = null;
    private string searchText { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (IdProject is null || IdProject == -1)
        {
            // Note: ParameterSet is also invoked when navigating away from the current URL, causing the query
            // and its parameters to change. This can trigger a race condition (or a predetermined execution order)
            // that activates the following condition. Since we only care about the IdIs value when on the overview,
            // we safely ignore it otherwise.
            // Overriding with a separate function was considered, but would break the existing behavior.
            if (Navigator.Uri.Contains("Overview"))
            {
                //Id Project must no be null
                Navigator.NavigateTo("/");
            }

            return;
        }

        if (IdItem == -1)
        {
            topLayer = LayerType.Item;
        }
        else if (IdAsset == -1)
        {
            topLayer = LayerType.Asset;
        }
        else if (IdDamageScenario == -1)
        {
            topLayer = LayerType.DamageScenario;
        }
        else if (IdThreatScenario == -1)
        {
            topLayer = LayerType.ThreatScenario;
        }

        if (IdThreatScenario == -1)
        {
            bottomLayer = LayerType.ThreatScenario;
        }
        else if (IdDamageScenario == -1)
        {
            bottomLayer = LayerType.DamageScenario;
        }
        else if (IdAsset == -1)
        {
            bottomLayer = LayerType.Asset;
        }
        else if (IdItem == -1)
        {
            bottomLayer = LayerType.Item;
        }
        else if (IdProject == -1)
        {
            bottomLayer = LayerType.Project;
        }


        //Fallback: no wildcards found — redirect to the deepest entity page instead of Overview
        if (topLayer is null && bottomLayer is null)
        {
            if (IdThreatScenario is not null)
                Navigator.NavigateTo($"/ThreatScenario/{IdThreatScenario}");
            else if (IdDamageScenario is not null)
                Navigator.NavigateTo($"/DamageScenario/{IdDamageScenario}");
            else if (IdAsset is not null)
                Navigator.NavigateTo($"/Asset/{IdAsset}");
            else if (IdItem is not null)
                Navigator.NavigateTo($"/Item/{IdItem}");
            else
                Navigator.NavigateTo("/");
            return;
        }

        //Catch invalid States
        if (topLayer is null || bottomLayer is null)
        {
            Navigator.NavigateTo("/");
            return;
        }

        if ((int)topLayer! > (int)bottomLayer!)
        {
            Navigator.NavigateTo("/");
            return;
        }

        renderKey++;
        StateHasChanged();

    }
}
