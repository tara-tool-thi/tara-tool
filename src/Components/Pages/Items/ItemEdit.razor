@page "/Item/{itemId:long}"
@rendermode InteractiveServer

@using tara_tool.Components.Dialogs
@using tara_tool.Data.Services
@using tara_tool.Data.Tables

@inject ItemDefinitionService ItemsService
@inject NavigationManager NavigationManager
@inject AssetService AssetService
@inject IDialogService DialogService
@inject AccessControlService AccessControlService

<PageTitle>Item Definition</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Stretch"
             HorizontalAlignment="HorizontalAlignment.SpaceBetween">
    <h2>Item Definition</h2>
    <FluentIcon Id="item-edit-info-icon" Value="@(new Icons.Regular.Size24.Info())" />
    <FluentTooltip Anchor="item-edit-info-icon" MaxWidth="450px">
        <p><strong>Item Definition</strong></p>
        <p>Define the system under analysis, its functions, and its operational environment. This page sets the scope of the entire TARA.</p>
        <p class="tooltip-section-heading">Item Name</p>
        <p>Unique, project-wide consistent short name — without a version number. Example: <em>"EV Battery Pack"</em></p>
        <p class="tooltip-section-heading">Item Description</p>
        <p>Short summary of what the item is and what it does. Example: <em>"HV storage with BMS/CMC, CAN connection to gateway."</em></p>
        <p class="tooltip-section-heading">Technical Sketch</p>
        <p>Upload a block diagram, architecture sketch, or photo of the item via drag &amp; drop or the browse link. Helps reviewers understand the boundary at a glance.</p>
        <p class="tooltip-section-heading">Item Boundary</p>
        <p>Define what is in scope and what is explicitly out of scope. Everything outside the boundary is treated as the environment.</p>
        <p class="tooltip-section-heading">Item Functions</p>
        <p>List the functions the item provides to the vehicle or user. Each function should later be traceable to assets and damage scenarios.</p>
        <p class="tooltip-section-heading">Preliminary Architecture</p>
        <p>Components, interfaces, and data flows inside the item. Names used here should match the assets defined below.</p>
        <p class="tooltip-section-heading">Operational Environment</p>
        <p>Conditions and assumptions under which the item operates (temperature range, network access, user roles, …). Assumptions made explicit here determine which threats are relevant.</p>
        <p class="tooltip-section-heading">Assets</p>
        <p>List of all valuable objects with cybersecurity relevance. Each row shows Nr., Name, Description, Group, and the number of Damage Scenarios already attached.</p>
        <div class="tooltip-tip">
            <strong>Tip:</strong> Each asset will later have its own TARA branch — better to define one asset too many than one too few.
        </div>
    </FluentTooltip>
    @if (itemDefinition != null && itemDefinition.Project != null && itemDefinition.Project.IsArchived)
    {
        <FluentBadge Appearance="Appearance.Neutral" Class="badge-archived">
            <FluentIcon Value="@(new Icons.Regular.Size16.Archive())" Class="icon-spacing" />
            Archived
        </FluentBadge>
    }
    else if (itemDefinition != null && itemDefinition.Project != null && hasWriteAccess)
    {
        <GenericAutosave TEntity="ItemDefinition" Entity="@itemDefinition" SaveService="@ItemsService"
                         @ref=@genericAutosave />
    }
    else
    {
        <FluentBadge Appearance="Appearance.Neutral" Class="badge-archived">
            <FluentIcon Value="@(new Icons.Regular.Size16.Warning())" Class="icon-spacing" />
            You are not allowed to write on this project, changes will not be saved!
        </FluentBadge>
    }
    <FluentSpacer />
    <FluentButton Appearance="Appearance.Outline" OnClick="@deletionDialog.Show" Color="var(--error)" Title="Delete item">
        <FluentIcon Value="@(new Icons.Regular.Size20.Delete())" Color="Color.Error" Slot="start" />
        Delete Item
    </FluentButton>
</FluentStack>

<p class="tiny-text">Define the item, its boundaries, and manage its assets.</p>

<DeletionDialog ItemName="@itemDefinition?.ItemName" OnDelete="DeleteAsync" @ref=@deletionDialog />

@if (itemDefinition == null)
{
    <FluentProgressRing />
}
else
{
    <BackButton />
    <FluentStack Orientation="Orientation.Vertical" Width="100%">
        <div class="fullwidth">
            <FluentTextField @bind-Value="itemDefinition!.ItemName" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave()) Label="Item Name" Placeholder="Enter item name..." Class="fullwidth"
                             Immediate="true" ImmediateDelay="500" Autofocus="true" />
        </div>

        <div class="fullwidth">
            <FluentTextArea @bind-Value="itemDefinition!.ItemDescription" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave()) Label="Item Description"
                            Placeholder="Describe the item and its purpose..." Rows="4" Class="fullwidth" Immediate="true"
                            ImmediateDelay="500" />
        </div>

        <FluentStack Orientation="Orientation.Vertical">
            <FluentStack VerticalAlignment="VerticalAlignment.Center">
                <FluentLabel>Technical Sketch</FluentLabel>
                @if (imagePreviewUrl is not null)
                {
                    <FluentButton Appearance="Appearance.Outline" OnClick="RemoveImage" Color="var(--error)" Title="Remove technical sketch">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Delete())" Color="Color.Error" Slot="start" />
                        Remove
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.FullScreenMaximize())"
                                  OnClick="ShowTechnicalSketch" Title="Show technical sketch">
                        Show
                    </FluentButton>
                }
            </FluentStack>
            @if (imagePreviewUrl is not null)
            {
                <img src="@imagePreviewUrl" alt="Technical sketch preview" class="technical-sketch-preview" height="200"
                     @onclick="@ShowTechnicalSketch" />
            }
            else
            {
                <FluentInputFile OnInputFileChange="OnFileSelected" Accept="image/*" MaximumFileCount="1"
                                 MaximumFileSize="@(10 * 1024 * 1024)" DragDropZoneVisible="true" Id="techSketch"
                                 Style="width: 100%; min-height: 120px;">
                    <ChildContent>
                        <br>
                        <label for="techSketch">
                            <FluentIcon Value="@(new @Icons.Regular.Size24.ArrowUpload())" />
                        </label>
                        <div>
                            To upload a file, drag it here
                            or <label for="techSketch">browse</label>
                            for it.
                        </div>
                    </ChildContent>
                </FluentInputFile>
            }
        </FluentStack>

        <FluentAccordion Class="fullwidth">
            <FluentAccordionItem Expanded="@ExpandedItemBoundaryText">
                <HeadingTemplate>
                    <strong>Item Boundary</strong>
                </HeadingTemplate>
                <ChildContent>
                    <FluentTextArea @bind-Value="itemDefinition!.ItemBoundaryText" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave()) Placeholder="Describe the item boundaries and interfaces..."
                                    Rows="5" Class="fullwidth" Immediate="true" ImmediateDelay="500" />
                </ChildContent>
            </FluentAccordionItem>
            <FluentAccordionItem Expanded="@ExpandedItemFunction">
                <HeadingTemplate>
                    <strong>Item Functions</strong>
                </HeadingTemplate>
                <ChildContent>
                    <FluentTextArea @bind-Value="itemDefinition!.ItemFunction" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave()) Placeholder="List the functions this item fulfills..." Rows="5"
                                    Class="fullwidth" Immediate="true" ImmediateDelay="500" />
                </ChildContent>
            </FluentAccordionItem>
            <FluentAccordionItem Expanded="@ExpandedPreliminaryArchitectureText">
                <HeadingTemplate>
                    <strong>Preliminary Architecture</strong>
                </HeadingTemplate>
                <ChildContent>
                    <FluentTextArea @bind-Value="itemDefinition!.PreliminaryArchitectureText" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave()) Placeholder="Describe the preliminary architecture..." Rows="5"
                                    Class="fullwidth" Immediate="true" ImmediateDelay="500" />
                </ChildContent>
            </FluentAccordionItem>
            <FluentAccordionItem Expanded="@ExpandedOperationalEnvironmentText">
                <HeadingTemplate>
                    <strong>Operational Environment</strong>
                </HeadingTemplate>
                <ChildContent>
                    <FluentTextArea @bind-Value="itemDefinition!.OperationalEnvironmentText" @bind-Value:after=@(() => genericAutosave.ScheduleAutoSave())
                                    Placeholder="Describe the operational environment and operating conditions..." Rows="5"
                                    Class="fullwidth" Immediate="true" ImmediateDelay="500" />
                </ChildContent>
            </FluentAccordionItem>
        </FluentAccordion>

        <br />
        <hr />
        <br />

        <FluentAccordion ActiveId="@activeId" Class="fullwidth accordion" Style="margin-bottom: 60px;">  
            <FluentAccordionItem Expanded="true">
                <HeadingTemplate>
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                                 HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                        <span><strong>Assets</strong></span>
                        <FluentSpacer />
                        <FluentButton IconStart=@(new Icons.Regular.Size20.Add()) OnClick="CreateNewAsset"
                                      Appearance="Appearance.Accent" Title="New Asset">
                            New Asset
                        </FluentButton>
                    </FluentStack>
                </HeadingTemplate>
                <ChildContent>
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Stretch"
                                 HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                            <FluentSearch Immediate=true ImmediateDelay="500" @bind-Value="@assetSearchText"
                                          Placeholder="Search by name, description or group" Class="search-width" />
                        <FluentSpacer />
                        <div>
                            <FluentCheckbox Label="Only show Assets with no Damage Scenarios"
                                            @bind-Value="@showAssetsWithNoDamageScenario" />
                        </div>
                    </FluentStack>
                    <AssetTable @ref="@assetTable"
                                Filters="@(p => p.Where(a => a.IdItemDefinition == itemId).Where(a => string.IsNullOrWhiteSpace(assetSearchText) || a.AssetName.Contains(assetSearchText) || a.Description.Contains(assetSearchText) ||
                                                                                                                                                                                    a.Tag!.Name.Contains(assetSearchText) || (a.Tag == null && " None".Contains(assetSearchText)))
                                                                                                                                                                                        .Where(a =>
                                                                                                                                                                                                showAssetsWithNoDamageScenario == false || a.DamageScenarios.Count() == 0))"
                                ProjectId="@itemDefinition.IdProject" />
                </ChildContent>
            </FluentAccordionItem>
        </FluentAccordion>
    </FluentStack>

    <br />
    <br />
    <br />
}

@code {
    [Parameter]
    public long itemId { get; set; }

    string activeId = "TableAccordion";
    ItemDefinition? itemDefinition;
    GenericAutosave<ItemDefinition> genericAutosave = default!;
    DeletionDialog deletionDialog = default!;
    string? imagePreviewUrl;
    AssetTable? assetTable;

    private string _assetSearchText = string.Empty;
    private string assetSearchText
    {
        get => _assetSearchText;
        set
        {
            _assetSearchText = string.IsNullOrWhiteSpace(value) ? string.Empty : value;
            assetTable?.RefreshGrid();
        }
    }

    private bool _showAssetsWithNoDamageScenario = false;
    private bool showAssetsWithNoDamageScenario
    {
        get => _showAssetsWithNoDamageScenario;
        set
        {
            _showAssetsWithNoDamageScenario = value;
            assetTable?.RefreshGrid();
        }
    }
    bool ExpandedItemBoundaryText = false;
    bool ExpandedItemFunction = false;
    bool ExpandedPreliminaryArchitectureText = false;
    bool ExpandedOperationalEnvironmentText = false;
    bool hasWriteAccess = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            itemDefinition = await ItemsService.GetItemByIdAsync(itemId, include: e => e.Include(i =>
            i.TechnicalSketch).Include(i
        => i.PreliminaryArchitecture).Include(i => i.ItemBoundary).Include(i => i.OperationalEnvironmentImage).Include(i
            =>
        i.Project));

            if (itemDefinition == null)
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            if (itemDefinition.Project != null)
            {
                hasWriteAccess = await AccessControlService.CheckUserAccessRightsWrite(itemDefinition.Project.Id);
            }

            ExpandedItemBoundaryText = !string.IsNullOrEmpty(itemDefinition.ItemBoundaryText);
            ExpandedItemFunction = !string.IsNullOrEmpty(itemDefinition.ItemFunction);
            ExpandedPreliminaryArchitectureText = !string.IsNullOrEmpty(itemDefinition.PreliminaryArchitectureText);
            ExpandedOperationalEnvironmentText = !string.IsNullOrEmpty(itemDefinition.OperationalEnvironmentText);

            if (itemDefinition.TechnicalSketch?.Data != null)
                imagePreviewUrl = $"data:image/png;base64,{Convert.ToBase64String(itemDefinition.TechnicalSketch.Data)}";
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading item: {ex.Message}");
            NavigationManager.NavigateTo("/");
        }
    }

    async Task OnFileSelected(InputFileChangeEventArgs fileArgs)
    {
        if (fileArgs.File == null || itemDefinition == null) return;

        using MemoryStream ms = new();
        await fileArgs.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
        byte[] bytes = ms.ToArray();

        imagePreviewUrl = $"data:{fileArgs.File.ContentType};base64,{Convert.ToBase64String(bytes)}";

        if (itemDefinition.TechnicalSketch == null)
        {
            itemDefinition.TechnicalSketch = new Image(bytes) { Id = 0 };
        }

        else
        {
            itemDefinition.TechnicalSketch.Data = bytes;
        }
        genericAutosave.ScheduleAutoSave();
    }

    async Task ShowTechnicalSketch()
    {
        if (itemDefinition is null or { TechnicalSketch: null }) return;

        await DialogService.ShowDialogAsync<ImageViewer>(itemDefinition.TechnicalSketch, new DialogParameters
        {
            Title =
    "Technical Sketch",
        });
    }

    void RemoveImage()
    {
        if (itemDefinition == null) return;
        imagePreviewUrl = null;
        itemDefinition.TechnicalSketch = null;
        genericAutosave.ScheduleAutoSave();
    }

    async Task DeleteAsync()
    {
        if (itemDefinition == null) return;
        long projectId = itemDefinition.IdProject;
        await ItemsService.Delete(itemDefinition);
        NavigationManager.NavigateTo($"/Project/{projectId}");
    }

    async void CreateNewAsset()
    {
        Asset? asset = await AssetService.CreateNewAsset(itemId);
        if (asset is not null)
        {
            NavigationManager.NavigateTo($"Asset/{asset!.Id}");
        }
    }
}
