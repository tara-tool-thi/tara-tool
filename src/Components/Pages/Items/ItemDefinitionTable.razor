@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject ItemDefinitionService ItemDefinitionService

@if (paginationUI is not null)
{
    <FluentDataGrid TGridItem="ItemDefinition" ItemsProvider=@FilteredItemsProvider Pagination="@paginationUI.pagination" AutoFit=true
                    OnRowClick="onRowClick" RowStyle="@(item => "cursor: pointer;")" Style="max-height:50%; overflow:auto;" @ref="grid">
        <TemplateColumn Sortable="true" SortBy="@itemNumberSort" Title="Nr." Width="70px">
            @($"{context.ItemNumber}.")
        </TemplateColumn>
        <PropertyColumn Property="@(p => p.ItemName)" Sortable="true" Title="Item Name" />
        <PropertyColumn Property="@(p => p.ItemFunction)" Sortable="true" Title="Item Function" />
        <PropertyColumn Property="@(p => p.OperationalEnvironmentText)" Sortable="true" Title="Operational Environment" />
    </FluentDataGrid>
}

<PaginationUI @ref=@paginationUI />

@code {
    [Parameter]
    public required long ProjectId { get; set; }

    [Parameter]
    public Func<IQueryable<ItemDefinition>, IQueryable<ItemDefinition>>? Filters { get; set; }

    private GridItemsProvider<ItemDefinition> FilteredItemsProvider { get; set; } = default!;
    private PaginationUI paginationUI { get; set; } = default!;
    private FluentDataGrid<ItemDefinition> grid = default!;
    private GridSort<ItemDefinition> itemNumberSort = GridSort<ItemDefinition>.ByAscending(item => item.ItemNumber);

    public void RefreshGrid()
    {
        if (grid is not null)
            InvokeAsync(() => grid.RefreshDataAsync());
    }

    private void onRowClick(FluentDataGridRow<ItemDefinition> row)
    {
        if (row.Item is null)
        {
            return;
        }
        NavigationManager.NavigateTo($"/Item/{row.Item.Id}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        FilteredItemsProvider = ItemDefinitionService.GetItemsProvider(ProjectId, null, Filters);
    }
}
