@page "/Project/{urlId:long}"

@rendermode InteractiveServer
@inject ItemDefinitionService ItemsService

@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.Configuration
@using Mono.TextTemplating
@using tara_tool.Data.Services
@using tara_tool.Data.Tables


<!-- Db Context has to be swapped from ApplicationDbContext to IDbContextFactory as per our guidelines -->
<!-- for IDbContextFactory to work I would have to swap
    builder.Services.AddDbContext<ApplicationDbContext>(
    options => options.UseSqlite(connectionString));
    for
    builder.Services.AddDbContextFactory<ApplicationDbContext>(
    options => options.UseSqlite(connectionString));
    in Program.cs -->

@inject NavigationManager NavigationManager
@inject ProjectService ProjectService
@inject AccessControlService AccessControlService
@inject DateTimeService DateTimeService


<PageTitle>Project</PageTitle>

<br />
<FluentStack>
    <h2>
        <FluentStack Orientation="Orientation.Horizontal"
                     VerticalAlignment="VerticalAlignment.Center"
                     @key="@retrievedProjectLastModifiedDate">
            @if (isRenamingProjectName)
            {
                <FluentTextField @bind-Value="newProjectName"
                                 Placeholder="Project name"
                                 Class="project-name-input" />

                <FluentButton Appearance="Appearance.Accent" OnClick="SaveProjectNameAsync">
                    Save
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline" OnClick="CancelRenameProjectName">
                    Cancel
                </FluentButton>
            }
            else
            {
                @projectName
                @if (canManage && !isArchived)
                {
                    <FluentButton Appearance="Appearance.Stealth"
                        Title="Rename project"
                        IconStart="@(new Icons.Regular.Size20.Edit())"
                        OnClick="StartRenameProjectName" />
                }
            }

            @if (isArchived)
            {
                <FluentBadge Appearance="Appearance.Neutral" Class="badge-archived">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Archive())" Class="icon-spacing" />
                    Archived
                </FluentBadge>
            }
            <FluentSpacer />
        </FluentStack>
    </h2>
    <FluentSpacer />
    <span class="tiny-text">Last Edited: @retrievedProjectLastModifiedDate</span>


    @if (canManage)
    {
        <FluentButton Appearance="Appearance.Outline" Title="Project Settings"
                      IconStart="@(new Icons.Regular.Size20.Settings())"
                      OnClick="@(() => NavigationManager.NavigateTo($"/Project/{urlId}/Settings"))" />
    }

</FluentStack>

@if (isArchived)
{
    <FluentMessageBar Intent="MessageIntent.Warning" Style="margin-bottom:12px">
        This project is archived and cannot be edited.
    </FluentMessageBar>
}
<br />
<FluentStack VerticalAlignment="VerticalAlignment.Bottom">
    <FluentTextField Label="Search for an Item" Placeholder="Search by name, function or environment"
                     Style="width: 250px;" @bind-Value="searchText" Immediate="true" ImmediateDelay="500" />
    <FluentSpacer />

    @if (!isArchived)
    {
        <FluentButton IconStart="@(new Icons.Regular.Size16.Add())" OnClick="@(() => addItem("New unnamed Item"))">
            New Item
        </FluentButton>
    }
</FluentStack>

<br />
<ItemDefinitionTable @ref="@table" ProjectId="@urlId"
                     Filters="@(e => e.Where(i => i.IdProject == urlId).Where(i =>
                                                                                   string.IsNullOrWhiteSpace(searchText) ||
                                                                                   EF.Functions.Like(i.ItemName, $"%{searchText}%") ||
                                                                                   EF.Functions.Like(i.ItemFunction ?? string.Empty, $"%{searchText}%") ||
                                                                                   EF.Functions.Like(i.OperationalEnvironmentText ?? string.Empty, $"%{searchText}%")))" />

<BackButton />

@code {
    [Parameter]
    public long urlId { get; set; }

    private string projectName = "";
    private bool canManage = false;
    private bool isArchived = false;
    private bool isRenamingProjectName = false;
    private string newProjectName = "";

    private DateTime retrievedProjectLastModifiedDate;
    private bool localDateTimeUpdatePending;

    private string searchText
    {
        get => field;
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                field = string.Empty;
            }

            else
            {
                field = value;
            }
            table?.RefreshGrid();
        }
    } = string.Empty;

    private ItemDefinitionTable? table;

    protected override async Task OnParametersSetAsync()
    {
        //New project has to be created when urlId == -1
        if (urlId == -1)
        {
            Project? newProject = await ProjectService.CreateNewProjectAsync("New unnamed Project");

            if (newProject is null)
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            NavigationManager.NavigateTo($"/Project/{newProject.Id}", replace: true);

            return;
        }

        Project? requestedProject = await retrieveProjectInfo();

        if (requestedProject == null)
        {
            NavigationManager.NavigateTo("/");

            return;
        }

        projectName = requestedProject!.ProjectName;
        retrievedProjectLastModifiedDate = requestedProject.DateLastChanged;
        isArchived = requestedProject.IsArchived;
        localDateTimeUpdatePending = true;
        canManage = await AccessControlService.CheckUserAccessRightsManage(urlId);

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (localDateTimeUpdatePending)
        {
            localDateTimeUpdatePending = false;
            retrievedProjectLastModifiedDate = await DateTimeService.GetLocalDateTime(retrievedProjectLastModifiedDate);
            StateHasChanged();
        }
    }


    private async Task<Project?> retrieveProjectInfo()
    {
        Project? retrievedProject = await ProjectService.GetItemByIdAsync(urlId, null);

        return retrievedProject;
    }

    private void StartRenameProjectName()
    {
        newProjectName = projectName;
        isRenamingProjectName = true;
    }

    private void CancelRenameProjectName()
    {
        newProjectName = string.Empty;
        isRenamingProjectName = false;
    }

    private async Task SaveProjectNameAsync()
    {
        string trimmedProjectName = newProjectName.Trim();

        if (string.IsNullOrWhiteSpace(trimmedProjectName)) 
        {
            return;
        }

        await ProjectService.UpdateProjectNameAsync(urlId, trimmedProjectName);

        Project? requestedProject = await retrieveProjectInfo();

            if (requestedProject != null)
            {
                projectName = requestedProject.ProjectName;
                retrievedProjectLastModifiedDate = requestedProject.DateLastChanged;
            }

        isRenamingProjectName = false;
    }


    private async Task addItem(string name)
    {
        try
        {
            ItemDefinition? newItem = await ItemsService.CreateItemAsync(urlId, name);

            if (newItem == null)
            {
                return;
            }

            Project? requestedProject = await retrieveProjectInfo();

            if (requestedProject != null)
            {
                projectName = requestedProject.ProjectName;
                retrievedProjectLastModifiedDate = requestedProject.DateLastChanged;
            }
            await ItemsService.Save(newItem);
            NavigationManager.NavigateTo($"/Item/{newItem.Id}");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error adding item: {ex.Message}");
        }
    }


}