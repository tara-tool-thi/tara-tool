@using tara_tool.Data.Tables

@rendermode InteractiveServer
@inject ProjectService ProjectService
@inject SessionService SessionService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<FluentStack Class="toolbar-stack" Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Stretch"
             HorizontalAlignment="HorizontalAlignment.Left">
    <FluentSearch Placeholder="Search projects by name…" Class="search-field" @bind-Value=@TitleSearch Immediate=true
                  ImmediateDelay="500" />
    <FluentButton id="SelectOwnerPopoverButton" OnClick="@(() => openOwnerPopover = !openOwnerPopover)">
        @if (openOwnerPopover)
        {
            <FluentIcon Value=@(new Icons.Regular.Size16.ChevronUp()) Color="Color.Neutral" Slot="end" />
        }
        else
        {
            <FluentIcon Value=@(new Icons.Regular.Size16.ChevronDown()) Color="Color.Neutral" Slot="end" />
        }
        Filter by Owner
    </FluentButton>

    <FluentPopover @bind-Open="@openOwnerPopover" AnchorId="SelectOwnerPopoverButton">

        <Body>
            @if (allEmails.Count() == 0)
            {
                <p>No E-Mails available</p>
            }
            else
            {
                <FluentSelect TOption="string" Placeholder="Select an Owner..." Items=@allEmails Multiple=@true
                              Class="fullwidth" @bind-SelectedOptions="@selectedMails">
                    <OptionTemplate>
                        @context
                    </OptionTemplate>
                </FluentSelect>
            }
        </Body>
    </FluentPopover>

    <FluentButton Appearance="@(showArchived ? Appearance.Accent : Appearance.Neutral)"
                  Title="@(showArchived ? "Hide archived projects" : "Show archived projects")"
                  OnClick="@(() => showArchived = !showArchived)">
        <FluentIcon Value="@(new Icons.Regular.Size16.Archive())" Slot="start" Color="@(showArchived ? Color.Fill : Color.Neutral)" />
        Archived
    </FluentButton>

    <FluentButton Appearance="Appearance.Outline"
                  Title="Import project"
                  OnClick="@(() => showImportDialog = true)">
        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowImport())" Slot="start" />
        Import
    </FluentButton>
</FluentStack>

<!-- Import Dialog -->
<FluentDialog Hidden="@(!showImportDialog)" Modal="true" TrapFocus="true" aria-label="Import project">
    <FluentDialogHeader>
        <h3>Import project</h3>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical">
            <span>Paste the project JSON string here:</span>
            <FluentTextArea @bind-Value="importJson"
                             Placeholder="Paste JSON..."
                             Class="fullwidth" />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentStack Orientation="Orientation.Horizontal" Width="100%">
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Outline"
                          OnClick="@(() => { showImportDialog = false; importJson = string.Empty; })">
                Cancel
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="ImportAsync">
                Import
            </FluentButton>
        </FluentStack>
    </FluentDialogFooter>
</FluentDialog>

@if (allProjectsWithAccess.Count() != 0)
{
    <div @key=@TitleSearch>
        @foreach (var project in allProjectsWithAccess.Where(project =>
            (showArchived || !project.IsArchived) &&
            (TitleSearch == null || project.ProjectName.Contains(TitleSearch)) &&
            (selectedMails.Count() == 0 ||
                selectedMails.Contains(project.Access?.FirstOrDefault(accessControl => accessControl.Owner ==
                    true)?.ApplicationUser.Email ?? string.Empty))))
        {
            <ProjectCard Project=@project />
        }
    </div>
}

@code {
    List<Project> allProjectsWithAccess = new();
    IEnumerable<string> allEmails = [];
    IEnumerable<string> selectedMails = [];

    private bool openOwnerPopover = false;
    private bool showArchived = false;
    private bool showImportDialog = false;
    private string importJson = string.Empty;

    private string? _titleSearchBack = null;
    private string? TitleSearch
    {
        get => _titleSearchBack;
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                _titleSearchBack = null;
            }
            else
            {
                _titleSearchBack = value;
            }
            StateHasChanged();
        }
    }


    protected override async Task OnInitializedAsync()
    {

        ApplicationUser? user = await SessionService.GetApplicationUserAsync();

        if (user is null)
        {
            NavigationManager.NavigateTo("Account/InvalidUser");
            return;
        }

        allProjectsWithAccess = await ProjectService.GetProjectsAsync((value) => value.Include(a =>
        a.Access).ThenInclude(a => a.ApplicationUser));
        allEmails = allProjectsWithAccess.SelectMany(a => a.Access).Where(a => a.Owner == true).Select(a =>
a.ApplicationUser).Where(m =>
    m.Email != null).Select(m => m.Email!).Distinct().ToList();
    }

    private async Task OnSearchAsync(OptionsSearchEventArgs<string> e)
    {
        e.Items = allEmails.Where(s => s.Contains(e.Text, StringComparison.OrdinalIgnoreCase)).OrderBy(s => s);
    }

    private async Task ImportAsync()
    {
        if (string.IsNullOrWhiteSpace(importJson))
        {
            ToastService.ShowError("Please paste project JSON.");
            return;
        }

        bool success = await ProjectService.ImportProjectAsync(importJson);
        if (success)
        {
            showImportDialog = false;
            importJson = string.Empty;
            ToastService.ShowSuccess("Project imported successfully.");

            // Refresh list
            allProjectsWithAccess = await ProjectService.GetProjectsAsync((value) => value.Include(a =>
                a.Access).ThenInclude(a => a.ApplicationUser));
            StateHasChanged();
        }
        else
        {
            ToastService.ShowError("Failed to import project.");
        }
    }
}

