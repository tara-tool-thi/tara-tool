@page "/TS/{TSId:long}"

@rendermode InteractiveServer

@using tara_tool.Data.Services

@inject AccessControlService accessControlService

@inject ThreatScenarioService threatScenarioService

@inject NavigationManager NavigationManager


<PageTitle>Threat Scenario</PageTitle>

<FluentStack VerticalAlignment="VerticalAlignment.Center">
    <h2>Threat Scenario</h2>
    <FluentIcon Value="@(new Icons.Regular.Size24.Info())" id="iso-help-button" />
    <FluentTooltip Anchor="iso-help-button">
        <p><strong>ISO/SAE 21434 - Threat Scenario</strong></p>
        <p>The following aspects must be defined:</p>
        <ul>
            <li><strong>Placeholder:</strong> Placeholder</li>
        </ul>
    </FluentTooltip>
    <GenericAutosave TEntity="ThreatScenario" Entity="@thisTS" SaveService="@threatScenarioService"
                     @ref=@genericAutosave />
</FluentStack>

<FluentStack VerticalAlignment="VerticalAlignment.Center">
    <p class="tiny-text">Identify attack paths, assess attack feasibility, and determine the risk for each threat scenario.</p>

</FluentStack>

<FluentStack VerticalAlignment="VerticalAlignment.Center">
    <FluentSearch Placeholder="Free text search" Style="width: 25%;" @bind-Value=@searchText Immediate=true
                  ImmediateDelay="500" />
    <FluentSpacer/>
    <FluentButton Appearance="Appearance.Outline" OnClick="@(() => showDeleteDialog = true)" Color="var(--error)">
        <FluentIcon Value="@(new Icons.Regular.Size20.Delete())" Color="Color.Error" Slot="start" />
        Delete
    </FluentButton>
</FluentStack>

<div style="height: 1rem;"></div>

<FluentStack>
    <div style="display: flex; border: 1px solid #8a8886; width: 100%; margin-bottom: 4px;">
		<div style="display: flex; align-items: center; justify-content: center; border-right: 1px solid #8a8886; padding: 0 20px; font-weight: bold;">
			@TSName
		</div>

		<div style="flex-grow: 1; background-color: @BgColor; padding: 8px 15px; display: flex; align-items: center;">
			<span style="font-weight: 600; margin-right: 8px;">@TSDescription</span>
		</div>

		<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4px 15px; min-width: 80px; border-left: 1px solid #8a8886;">
			<span style="font-size: 0.9rem;">Risk:</span>
			<span style="color: @RiskColor; font-weight: bold;">@TSRiskValue</span>
		</div>
</div>
</FluentStack>

<FluentStack HorizontalAlignment="HorizontalAlignment.Center">
<FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="padding: 20px; width: 50%;" HorizontalAlignment="HorizontalAlignment.Center">
    @if (FilteredAttackPaths.Any())
    {

        int index = 1;

        @foreach (var path in FilteredAttackPaths)
        {
            @* Each box is now its own component *@
            <AttackPathCard @key="path.Id" attackPath="path" apNumber="index" OnFieldChanged="NotifyAutosave"/>
            ++index;
        }

    }
    else
    {
         @* This shows if the list is empty OR if the search returned zero results *@
        <FluentCard Style="text-align: center;">
            <FluentIcon Value="@(new Icons.Regular.Size24.Search())"/>
            <p>No attack paths found matching your search.</p>
        </FluentCard>
    }

    <FluentButton Appearance="Appearance.Neutral"
                OnClick="AddAP"
                Style="width: 100%;">
        <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Slot="start" />
        Add Attack Path
    </FluentButton>

</FluentStack>
</FluentStack>


<FluentDialog Hidden="@(!showDeleteDialog)" Modal="true" TrapFocus="true" aria-label="Delete confirmation">
    <FluentDialogHeader>
        <h3>Delete Threat Scenario</h3>
    </FluentDialogHeader>
    <FluentDialogBody>
        Are you sure you want to delete <strong>PLACEHOLDER - THREAT SCENARIO NAME HERE</strong>? This cannot be undone.
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentStack Orientation="Orientation.Horizontal" Width="100%" Style="gap: 0.5rem;">
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => showDeleteDialog = false)">Cancel
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" BackgroundColor="var(--error)" OnClick="DeleteAsync">Delete
            </FluentButton>
        </FluentStack>
    </FluentDialogFooter>
</FluentDialog>

<div style="height: 1rem;"></div>

@code {
    [Parameter]
    public long TSId { get; set; }

    GenericAutosave<ThreatScenario> genericAutosave = default!;

    bool showDeleteDialog = false;

    private string searchText
    {
        get => field;
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                field = string.Empty;
            }

            else
            {
                field = value;
            }
        }
    } = string.Empty;

    ThreatScenario? thisTS;

    private string TSName = string.Empty;
    private string TSDescription = string.Empty;
    private string TSRiskValue = string.Empty;

    public string BgColor { get; set; } = "#dff6ff"; // Default light blue
    public string RiskColor { get; set; } = "#d13438"; // Default red

    List<AttackPath> AttackPaths = new()
    {
        new AttackPath { Name = "AP1",  }
    };

    private IEnumerable<AttackPath> FilteredAttackPaths =>
        string.IsNullOrWhiteSpace(searchText)
            ? AttackPaths
            : AttackPaths.Where(ap =>
                // Check if any step contains the search text
                ap.Steps.Any(s => s.Text.Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
                // Check if RiskTreatment contains the search text
                (ap.RiskTreatmentText?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            );

    protected override async Task OnInitializedAsync()
    {
        thisTS = await threatScenarioService.GetItemByIdAsync(TSId, include: q =>
                                                                    q.Include(ts => ts.AttackPaths)
                                                                        .ThenInclude(ap => ap.Steps));
        if (thisTS == null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        TSName = thisTS.Name;
        TSDescription = thisTS.Description;
        TSRiskValue = thisTS.RiskValue.ToString();

        AttackPaths.Clear();

        foreach (AttackPath ap in thisTS.AttackPaths)
        {
            AttackPaths.Add(ap);
        }
    }

    async Task DeleteAsync()
    {

    }

    async Task AddAP()
    {
        AttackPath attackPath = new()
        {
            Name = "Test1", RiskTreatmentText = "Risky Business", Id = 1
        };

        await threatScenarioService.CreateAttackPathAsync(TSId, attackPath);

        AttackPaths.Add(attackPath);

        StateHasChanged();
    }

    void NotifyAutosave()
    {
        genericAutosave.ScheduleAutoSave();
    }
}